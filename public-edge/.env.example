ADMIN_EMAIL=admin@example.com
ACME_DNS_DOMAIN=authdns.example.com

# Optional. Defaults to ACME_DNS_DOMAIN.
# ACME_DNS_NSNAME=authdns.example.com

# Optional. Defaults to ADMIN_EMAIL converted to DNS SOA format:
# admin@example.com -> admin.example.com
# ACME_DNS_NSADMIN=admin.example.com

# Optional. init-server.sh auto-detects this when omitted.
# ACME_DNS_BIND_IP=203.0.113.10
