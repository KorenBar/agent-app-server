# SSH is always port 22 inside the container.
# Optional. setup-agent-app.sh defaults to 0.0.0.0 when
# OPEN_AGENT_APP_SSH_PORT=true, or 127.0.0.1 when false.
# AGENT_APP_SSH_BIND=0.0.0.0
AGENT_APP_SSH_PORT=2222

# Optional. Allows setup-agent-app.sh to open AGENT_APP_SSH_PORT/tcp in UFW.
OPEN_AGENT_APP_SSH_PORT=true

# Codex/Agent App state is fixed at /home/agent/.codex inside the container and
# persisted in ../volumes/agent-app/home/.codex.
CODEXUI_SANDBOX_MODE=danger-full-access
CODEXUI_APPROVAL_POLICY=never

# Optional. Enables passwordless sudo for the agent user on container startup.
# Keep false for normal use. Change to true only temporarily, then recreate the
# container so entrypoint can update /etc/sudoers.d/agent.
AGENT_APP_ENABLE_SUDO=false

# Prefer authorized_keys under ../volumes/agent-app/ssh/authorized_keys.
# AGENT_APP_AUTHORIZED_KEYS=ssh-ed25519 AAAA... your-key-name

# Optional. Enables password login for the agent user.
# AGENT_APP_PASSWORD=replace-with-a-long-secret

# Required for nginx-proxy/acme-companion.
AGENT_APP_DOMAIN=agent.example.com
ADMIN_EMAIL=admin@example.com

# Required for the external Authelia access gate. The auth domain must be one
# non-numeric direct subdomain under AGENT_APP_DOMAIN so it is covered by the
# wildcard cert and cannot collide with a dynamic port hostname.
AGENT_APP_AUTH_DOMAIN=auth.agent.example.com
AGENT_APP_AUTH_USERNAME=agent
AGENT_APP_AUTH_PASSWORD=replace-with-a-long-secret

# Optional. Authelia session lifetime defaults are intentionally longer than
# the old 5 minute idle timeout so the Agent App UI is not interrupted while in use.
AGENT_APP_AUTH_SESSION_INACTIVITY=12h
AGENT_APP_AUTH_SESSION_EXPIRATION=1d
AGENT_APP_AUTH_SESSION_REMEMBER_ME=1M

# Optional. auto enables SMTP only when outbound TCP/25 is reachable.
# Values: auto, true, false.
AGENT_APP_ENABLE_SMTP=auto

# Required only when SMTP notifications are enabled. Defaults to
# AGENT_APP_DOMAIN in setup. The sender is generated as
# Authelia <authelia@AGENT_APP_SMTP_DOMAIN>.
AGENT_APP_SMTP_DOMAIN=agent.example.com

# Optional. Sets the timezone for the container. Defaults to Asia/Jerusalem.
TZ=Asia/Jerusalem
